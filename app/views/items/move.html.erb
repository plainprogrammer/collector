<% content_for :title, "Move #{@card&.name || 'Item'}" %>

<div class="max-w-2xl mx-auto">
  <nav class="mb-6">
    <%= link_to item_path(@item), class: "inline-flex items-center gap-1 text-indigo-600 hover:text-indigo-800 transition-colors" do %>
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
      </svg>
      Back to Item
    <% end %>
  </nav>

  <h1 class="text-2xl font-bold text-gray-900 mb-6">Move Item</h1>

  <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-6">
    <%= render "card_preview", card: @card %>

    <div class="mb-6 p-4 bg-blue-50 border border-blue-200 rounded-lg">
      <h3 class="text-sm font-medium text-blue-800 mb-1">Current Location</h3>
      <p class="text-blue-700">
        <strong>Collection:</strong> <%= @item.collection.name %>
        <br>
        <strong>Storage:</strong> <%= @item.storage_unit&.name || "Loose (no storage unit)" %>
      </p>
    </div>

    <%= form_with model: @item, url: relocate_item_path(@item), method: :patch, local: true, class: "space-y-6",
        data: { controller: "move-item", turbo: false } do |f| %>

      <% if flash[:alert] %>
        <div class="bg-red-50 border border-red-200 rounded-lg p-4" data-testid="error-message">
          <p class="text-red-800"><%= flash[:alert] %></p>
        </div>
      <% end %>

      <fieldset>
        <legend class="text-sm font-medium text-gray-700 mb-3">New Location</legend>

        <div class="space-y-4">
          <div>
            <%= f.label :collection_id, "Collection", class: "block text-sm font-medium text-gray-700 mb-1" %>
            <%= f.select :collection_id,
                options_from_collection_for_select(@collections, :id, :name, @item.collection_id),
                {},
                class: "block w-full rounded-lg border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500",
                data: { action: "change->move-item#collectionChanged", move_item_target: "collectionSelect" } %>
          </div>

          <div>
            <%= f.label :storage_unit_id, "Storage Unit", class: "block text-sm font-medium text-gray-700 mb-1" %>
            <%= f.select :storage_unit_id,
                options_for_select(
                  [["No storage unit (loose)", ""]] + @storage_units.map { |u| [u.name, u.id] },
                  @item.storage_unit_id
                ),
                {},
                class: "block w-full rounded-lg border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500",
                data: { move_item_target: "storageSelect" } %>
            <p class="mt-1 text-xs text-gray-500" data-move-item-target="storageHint">
              <% if @item.collection_id != @collections.first&.id %>
                Note: Changing the collection will show storage units from the new collection.
              <% end %>
            </p>
          </div>
        </div>
      </fieldset>

      <div class="bg-yellow-50 border border-yellow-200 rounded-lg p-4" data-move-item-target="warning" style="display: none;">
        <div class="flex">
          <svg class="w-5 h-5 text-yellow-400 mr-2" fill="currentColor" viewBox="0 0 20 20">
            <path fill-rule="evenodd" d="M8.257 3.099c.765-1.36 2.722-1.36 3.486 0l5.58 9.92c.75 1.334-.213 2.98-1.742 2.98H4.42c-1.53 0-2.493-1.646-1.743-2.98l5.58-9.92zM11 13a1 1 0 11-2 0 1 1 0 012 0zm-1-8a1 1 0 00-1 1v3a1 1 0 002 0V6a1 1 0 00-1-1z" clip-rule="evenodd"/>
          </svg>
          <div>
            <h3 class="text-sm font-medium text-yellow-800">Moving to a different collection</h3>
            <p class="mt-1 text-sm text-yellow-700">
              The storage unit will be cleared since storage units belong to specific collections.
              You can select a new storage unit from the destination collection.
            </p>
          </div>
        </div>
      </div>

      <div class="flex justify-end gap-3 pt-4 border-t border-gray-200">
        <%= link_to "Cancel", item_path(@item), class: "px-4 py-2 border border-gray-300 rounded-lg text-gray-700 hover:bg-gray-50 transition-colors" %>
        <%= f.submit "Move Item",
            class: "px-4 py-2 bg-indigo-600 text-white rounded-lg hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:ring-offset-2 transition-colors" %>
      </div>
    <% end %>
  </div>
</div>
