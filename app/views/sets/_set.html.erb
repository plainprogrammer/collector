<article data-testid="set-card" class="bg-white rounded-lg shadow-sm border border-gray-200 hover:shadow-md transition-shadow">
  <%= link_to set_path(set.code), class: "block p-6", "aria-label": "View #{set.name} set" do %>
    <header class="flex items-start justify-between gap-2">
      <h2 data-testid="set-name" class="text-lg font-semibold text-gray-900 line-clamp-2"><%= set.name %></h2>
      <span data-testid="set-code" class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-gray-100 text-gray-800 flex-shrink-0">
        <%= set.code %>
      </span>
    </header>

    <div class="mt-3 space-y-1 text-sm text-gray-600">
      <p class="flex items-center gap-1">
        <svg class="w-4 h-4 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A1.994 1.994 0 013 12V7a4 4 0 014-4z"/>
        </svg>
        <span><%= set.type&.titleize || "Unknown" %></span>
      </p>
      <p data-testid="set-release-date" class="flex items-center gap-1">
        <svg class="w-4 h-4 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
        </svg>
        <time datetime="<%= set.releaseDate %>"><%= set.releaseDate %></time>
      </p>
      <p class="flex items-center gap-1">
        <svg class="w-4 h-4 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"/>
        </svg>
        <span><%= pluralize(set.cards.size, "card") %></span>
      </p>
    </div>
  <% end %>
</article>
