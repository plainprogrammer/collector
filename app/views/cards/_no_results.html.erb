<div class="text-center py-12 bg-gray-50 rounded-lg border-2 border-dashed border-gray-300">
  <svg class="mx-auto h-12 w-12 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.172 16.172a4 4 0 015.656 0M9 10h.01M15 10h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
  </svg>
  <h3 class="mt-4 text-lg font-semibold text-gray-900">No cards found</h3>
  <p class="mt-2 text-sm text-gray-600 max-w-md mx-auto">
    No cards match your search
    <% if params[:name].present? %>
      for "<%= params[:name] %>"
    <% end %>
    <% if params[:set_code].present? %>
      in set "<%= params[:set_code].upcase %>"
    <% end %>.
  </p>
  <div class="mt-4 text-sm text-gray-500">
    <p><strong>Try:</strong></p>
    <ul class="list-disc list-inside mt-2 space-y-1">
      <li>Check spelling</li>
      <li>Use partial name (e.g., "Bolt" instead of "Boltt")</li>
      <% if params[:set_code].present? %>
        <li>Remove the set code filter</li>
      <% end %>
    </ul>
  </div>
</div>
