<% content_for :title, @card.name %>

<article class="w-full" itemscope itemtype="https://schema.org/Product">
  <nav class="mb-6 flex gap-4">
    <%= link_to cards_path, class: "inline-flex items-center gap-1 text-indigo-600 hover:text-indigo-800 transition-colors" do %>
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
      </svg>
      Back to Search
    <% end %>
    <% if @card.set %>
      <%= link_to set_path(@card.setCode), class: "inline-flex items-center gap-1 text-indigo-600 hover:text-indigo-800 transition-colors" do %>
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"/>
        </svg>
        View Set
      <% end %>
    <% end %>
  </nav>

  <%= turbo_frame_tag "flash" do %>
    <%= render "shared/flash" %>
  <% end %>

  <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
    <aside class="lg:col-span-1">
      <%= render "card_image", card: @card %>
    </aside>

    <section class="lg:col-span-2 space-y-6">
      <header>
        <h1 class="text-3xl font-bold text-gray-900" itemprop="name"><%= @card.name %></h1>
        <% if @card.manaCost.present? %>
          <p class="mt-1 text-xl text-gray-600"><%= format_mana_cost(@card.manaCost) %></p>
        <% end %>
      </header>

      <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-6">
        <dl class="space-y-4">
          <div>
            <dt class="text-sm font-medium text-gray-500 uppercase tracking-wider">Type</dt>
            <dd class="mt-1 text-gray-900"><%= @card.type %></dd>
          </div>

          <% if @card.text.present? %>
            <div>
              <dt class="text-sm font-medium text-gray-500 uppercase tracking-wider">Rules Text</dt>
              <dd class="mt-1 text-gray-900 whitespace-pre-wrap"><%= @card.text %></dd>
            </div>
          <% end %>

          <% if @card.flavorText.present? %>
            <div>
              <dt class="text-sm font-medium text-gray-500 uppercase tracking-wider">Flavor Text</dt>
              <dd class="mt-1 text-gray-600 italic"><%= @card.flavorText %></dd>
            </div>
          <% end %>

          <div class="grid grid-cols-2 gap-4 pt-4 border-t border-gray-100">
            <% if @card.power.present? && @card.toughness.present? %>
              <div>
                <dt class="text-sm font-medium text-gray-500 uppercase tracking-wider">Power/Toughness</dt>
                <dd class="mt-1 text-gray-900 font-semibold"><%= @card.power %>/<%= @card.toughness %></dd>
              </div>
            <% end %>

            <% if @card.loyalty.present? %>
              <div>
                <dt class="text-sm font-medium text-gray-500 uppercase tracking-wider">Loyalty</dt>
                <dd class="mt-1 text-gray-900 font-semibold"><%= @card.loyalty %></dd>
              </div>
            <% end %>

            <div>
              <dt class="text-sm font-medium text-gray-500 uppercase tracking-wider">Rarity</dt>
              <dd class="mt-1"><%= render "sets/rarity_badge", rarity: @card.rarity %></dd>
            </div>

            <div>
              <dt class="text-sm font-medium text-gray-500 uppercase tracking-wider">Set</dt>
              <dd class="mt-1">
                <% if @card.set %>
                  <%= link_to set_path(@card.setCode), class: "text-indigo-600 hover:text-indigo-800" do %>
                    <%= @card.set.name %> (<%= @card.setCode %>)
                  <% end %>
                <% else %>
                  <%= @card.setCode %>
                <% end %>
              </dd>
            </div>

            <% if @card.number.present? %>
              <div>
                <dt class="text-sm font-medium text-gray-500 uppercase tracking-wider">Card Number</dt>
                <dd class="mt-1 text-gray-900"><%= @card.number %></dd>
              </div>
            <% end %>

            <% if @card.artist.present? %>
              <div>
                <dt class="text-sm font-medium text-gray-500 uppercase tracking-wider">Artist</dt>
                <dd class="mt-1 text-gray-900"><%= @card.artist %></dd>
              </div>
            <% end %>
          </div>
        </dl>
      </div>

      <%= render "legalities", legalities: @card.legalities.first %>

      <% if @card.rulings.any? %>
        <%= render "rulings", rulings: @card.rulings %>
      <% end %>
    </section>
  </div>

  <% if @other_printings.any? %>
    <%= render "other_printings", printings: @other_printings %>
  <% end %>

  <footer class="mt-8 pt-8 border-t border-gray-200">
    <%= render "add_to_collection", card: @card, collections: @collections %>
  </footer>
</article>
