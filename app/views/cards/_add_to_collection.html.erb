<div class="bg-gray-50 rounded-lg p-6" data-testid="add-to-collection">
  <h2 class="text-lg font-semibold text-gray-900 mb-4">Add to Collection</h2>

  <% if collections.any? %>
    <div class="flex flex-col sm:flex-row gap-4">
      <%= form_tag nil, method: :get, id: "add-to-collection-form", class: "flex-1 flex flex-col sm:flex-row gap-3" do %>
        <div class="flex-1">
          <%= select_tag :collection_id,
              options_from_collection_for_select(collections, :id, :name),
              prompt: "Select a collection...",
              class: "block w-full rounded-lg border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500",
              id: "collection-select",
              data: { card_uuid: card.uuid } %>
        </div>
        <button type="button"
                onclick="addToCollection()"
                class="inline-flex items-center justify-center gap-2 px-4 py-2 bg-indigo-600 text-white font-medium rounded-lg hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:ring-offset-2 transition-colors">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/>
          </svg>
          Add to Collection
        </button>
      <% end %>
    </div>
    <p class="mt-3 text-sm text-gray-500">
      Select a collection and click "Add to Collection" to add this card. You can specify condition, finish, and other details on the next page.
    </p>
  <% else %>
    <div class="text-center py-4">
      <p class="text-gray-600 mb-4">You don't have any collections yet.</p>
      <%= link_to new_collection_path,
          class: "inline-flex items-center gap-2 px-4 py-2 bg-indigo-600 text-white font-medium rounded-lg hover:bg-indigo-700 transition-colors" do %>
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/>
        </svg>
        Create a Collection
      <% end %>
    </div>
  <% end %>
</div>

<script>
  function addToCollection() {
    const select = document.getElementById('collection-select');
    const collectionId = select.value;
    const cardUuid = select.dataset.cardUuid;

    if (!collectionId) {
      alert('Please select a collection');
      return;
    }

    window.location.href = `/collections/${collectionId}/items/new?card_uuid=${cardUuid}`;
  }
</script>
